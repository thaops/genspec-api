{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": false,
    "assets": [{ "include": "catalog/data/*.json", "outDir": "dist", "watchAssets": true }]
  }
}
